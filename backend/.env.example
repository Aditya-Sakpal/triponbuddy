# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=triponbuddy

# AI Configuration
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://www.triponbuddy.com

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Cache Configuration
CACHE_TTL=3600
CACHE_MAXSIZE=1000

# Image Scraping Configuration
MAX_CONCURRENT_REQUESTS=50
IMAGE_SCRAPE_TIMEOUT=10
MAX_IMAGES_PER_LOCATION=5

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO
